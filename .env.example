# ═══════════════════════════════════════════════════════
# 🏢 BUSINESS BRANDING (Change these per client/agent)
# ═══════════════════════════════════════════════════════

# Your business / brand name shown in all bot messages
BUSINESS_NAME=Sri Homes

# A short tagline shown in the welcome message
BUSINESS_TAGLINE=Find your perfect property in Chennai!

# Business phone number (optional, shown in messages)
BUSINESS_PHONE=919876543210

# City name used in location question
BUSINESS_CITY=Chennai

# Comma-separated list of locations customers can choose from
# These become numbered options in the bot menu
BUSINESS_LOCATIONS=Anna Nagar,OMR,Velachery,Porur,Tambaram

# Comma-separated listing types (shown as numbered options)
# Use: Real Estate,Car  OR just: Real Estate  OR: Car,Bike,Commercial
BUSINESS_TYPES=Real Estate,Car

# Your website (optional — shown in confirmation message)
BUSINESS_WEBSITE=https://yourwebsite.com

# Emoji logo shown in welcome and confirmation messages
BUSINESS_LOGO_EMOJI=🏠

# ═══════════════════════════════════════════════════════
# 📊 GOOGLE SHEETS CONFIGURATION
# ═══════════════════════════════════════════════════════

# The ID of your Google Sheet (from the URL)
# e.g. https://docs.google.com/spreadsheets/d/THIS_IS_YOUR_SHEET_ID/edit
SHEET_ID=your_google_sheet_id_here

# Name of the sheet tab for listings (default: Listings)
SHEET_LISTINGS_TAB=Listings

# Name of the sheet tab where leads will be auto-saved (default: Leads)
SHEET_LEADS_TAB=Leads

# ═══════════════════════════════════════════════════════
# 🔐 GOOGLE SERVICE ACCOUNT CREDENTIALS
# ═══════════════════════════════════════════════════════

# Your Google Service Account email
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# Your Google Service Account Private Key
# IMPORTANT: Keep the \n characters, wrap in double quotes
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ═══════════════════════════════════════════════════════
# ⏰ FOLLOW-UP REMINDER SETTINGS
# ═══════════════════════════════════════════════════════

# Enable or disable visit reminders (true/false)
REMINDERS_ENABLED=true

# How many hours BEFORE the visit to send the reminder
# Default: 12 (reminder sent 12 hours before the visit)
REMINDER_HOURS_BEFORE=12

# ═══════════════════════════════════════════════════════
# 🤖 BOT SETTINGS
# ═══════════════════════════════════════════════════════

# Max number of listings to show per search
MAX_RESULTS=5

# Default agent WhatsApp number if no agent assigned in the sheet
# Format: country code + number + @c.us (e.g. 919876543210@c.us)
DEFAULT_AGENT_NUMBER=919876543210@c.us
