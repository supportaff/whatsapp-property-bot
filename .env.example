# ─────────────────────────────────────────────
# Google Sheets Configuration
# ─────────────────────────────────────────────

# The ID of your Google Sheet (from the URL)
# e.g. https://docs.google.com/spreadsheets/d/THIS_IS_YOUR_SHEET_ID/edit
SHEET_ID=your_google_sheet_id_here

# Name of the sheet tab for listings (default: Listings)
SHEET_LISTINGS_TAB=Listings

# Name of the sheet tab where leads will be saved (default: Leads)
SHEET_LEADS_TAB=Leads

# ─────────────────────────────────────────────
# Google Service Account Credentials
# ─────────────────────────────────────────────

# Your Google Service Account email
# Found in your service-account.json under "client_email"
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# Your Google Service Account Private Key
# Found in your service-account.json under "private_key"
# IMPORTANT: Keep the \n line breaks, wrap entire value in double quotes in .env
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ─────────────────────────────────────────────
# Bot Configuration
# ─────────────────────────────────────────────

# Your business/brand name shown in bot messages
BUSINESS_NAME=Sri Homes

# Max number of listings to show per search
MAX_RESULTS=5

# ─────────────────────────────────────────────
# Agent Notification
# ─────────────────────────────────────────────

# Default agent WhatsApp number to notify if no agent assigned in sheet
# Format: country code + number + @c.us (e.g. 919876543210@c.us)
DEFAULT_AGENT_NUMBER=919876543210@c.us
